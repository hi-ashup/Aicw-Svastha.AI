{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "env": {
    "VITE_GEMINI_API_KEY": {
      "description": "Google Gemini API Key for AI inference",
      "required": true
    },
    "VITE_FIREBASE_PROJECT_ID": {
      "description": "Firebase Project ID (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_API_KEY": {
      "description": "Firebase API Key (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_AUTH_DOMAIN": {
      "description": "Firebase Auth Domain (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_DATABASE_URL": {
      "description": "Firebase Database URL (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_STORAGE_BUCKET": {
      "description": "Firebase Storage Bucket (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_MESSAGING_SENDER_ID": {
      "description": "Firebase Messaging Sender ID (optional for build)",
      "required": false
    },
    "VITE_FIREBASE_APP_ID": {
      "description": "Firebase App ID (optional for build)",
      "required": false
    },
    "VITE_FIRESTORE_DATABASE_ID": {
      "description": "Firestore Database ID (optional for build)",
      "required": false
    }
  },
  "buildScript": "build",
  "devCommand": "vite --port 3000 --host 0.0.0.0",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
